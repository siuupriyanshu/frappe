{
 "name": "Appointment",
 "module": "Appointment System",
 "doctype": "DocType",
 "is_submittable": 1,
 "naming_rule": "naming_series",
 "autoname": "naming_series:",
 "track_changes": 1,
 "allow_import": 0,
 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "reqd": 1,
   "options": "APT-.YYYY.-.####",
   "description": "Auto-generated series"
  },
  {
   "fieldname": "section_patient",
   "fieldtype": "Section Break",
   "label": "Patient Information"
  },
  {
   "fieldname": "patient_name",
   "fieldtype": "Data",
   "label": "Patient Name",
   "reqd": 1
  },
  {
   "fieldname": "patient_email",
   "fieldtype": "Data",
   "label": "Patient Email",
   "options": "Email",
   "reqd": 1
  },
  {
   "fieldname": "patient_phone",
   "fieldtype": "Phone",
   "label": "Patient Phone"
  },
  {
   "fieldname": "column_doctor",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "doctor",
   "fieldtype": "Link",
   "label": "Doctor",
   "options": "Doctor",
   "reqd": 1
  },
  {
   "fieldname": "full_name",
   "fieldtype": "Read Only",
   "label": "Doctor Name",
   "fetch_from": "doctor.full_name"
  },
  {
   "fieldname": "specialization",
   "fieldtype": "Read Only",
   "label": "Specialization",
   "fetch_from": "doctor.specialization"
  },
  {
   "fieldname": "section_details",
   "fieldtype": "Section Break",
   "label": "Appointment Details"
  },
  {
   "fieldname": "appointment_date",
   "fieldtype": "Date",
   "label": "Appointment Date",
   "reqd": 1
  },
  {
   "fieldname": "appointment_time",
   "fieldtype": "Time",
   "label": "Appointment Time",
   "reqd": 1
  },
  {
   "fieldname": "column_timing",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "appointment_datetime",
   "fieldtype": "Datetime",
   "label": "Combined Datetime",
   "read_only": 1
  },
  {
   "fieldname": "slot_duration",
   "fieldtype": "Int",
   "label": "Duration (mins)",
   "fetch_from": "doctor.slot_duration"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Scheduled\nConfirmed\nCancelled\nCompleted",
   "reqd": 1,
   "default": "Scheduled"
  },
  {
   "fieldname": "section_reason",
   "fieldtype": "Section Break"
  },
  {
   "fieldname": "reason",
   "fieldtype": "Small Text",
   "label": "Reason for Visit",
   "reqd": 1
  },
  {
   "fieldname": "notes",
   "fieldtype": "Text",
   "label": "Notes"
  },
  {
   "fieldname": "section_billing",
   "fieldtype": "Section Break",
   "label": "Billing"
  },
  {
   "fieldname": "consultation_fee",
   "fieldtype": "Currency",
   "label": "Consultation Fee",
   "fetch_from": "doctor.consultation_fee"
  },
  {
   "fieldname": "payment_status",
   "fieldtype": "Select",
   "label": "Payment Status",
   "options": "Unpaid\nPaid\nWaived",
   "default": "Unpaid"
  },
  {
   "fieldname": "section_cancellation",
   "fieldtype": "Section Break",
   "label": "Cancellation",
   "depends_on": "eval:doc.status=='Cancelled'"
  },
  {
   "fieldname": "cancelled_by",
   "fieldtype": "Data",
   "label": "Cancelled By"
  },
  {
   "fieldname": "cancellation_reason",
   "fieldtype": "Small Text",
   "label": "Cancellation Reason"
  },
  {
   "fieldname": "confirmation_sent",
   "fieldtype": "Check",
   "label": "Confirmation Sent",
   "read_only": 1
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1
  }
 ]
}